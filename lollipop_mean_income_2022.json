{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 500,
  "title": {
    "text": "Malaysia Mean Household Income by State (2022)",
    "subtitle": "Monthly household income in Malaysian Ringgit (RM)",
    "fontSize": 16,
    "subtitleFontSize": 13,
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/bonkers69420/2179/refs/heads/main/hies_state.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {
      "filter": "datum.state !== 'W.P. Kuala Lumpur' && datum.state !== 'W.P. Labuan' && datum.state !== 'W.P. Putrajaya'"
    },
    {
      "calculate": "toNumber(datum.income_mean)",
      "as": "income_mean_num"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2,
        "color": "#C0392B"
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "income_mean_num", "order": "descending"},
          "title": null,
          "axis": {
            "labelFontSize": 12
          }
        },
        "x": {
          "datum": 0,
          "type": "quantitative"
        },
        "x2": {
          "field": "income_mean_num",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 120,
        "color": "#C0392B"
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "income_mean_num", "order": "descending"},
          "title": null
        },
        "x": {
          "field": "income_mean_num",
          "type": "quantitative",
          "title": "Mean Monthly Income (RM)",
          "axis": {
            "labelFontSize": 12,
            "titleFontSize": 13,
            "format": ",.0f"
          }
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "income_mean_num", "type": "quantitative", "title": "Mean Income (RM)", "format": ",.0f"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 12,
        "color": "#1A1A18"
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "income_mean_num", "order": "descending"}
        },
        "x": {
          "field": "income_mean_num",
          "type": "quantitative"
        },
        "text": {
          "field": "income_mean_num",
          "type": "quantitative",
          "format": ",.0f"
        }
      }
    }
  ]
}