{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "title": {
    "text": "Malaysia Absolute Poverty Rate (1970–2022)",
    "subtitle": "Percentage of households below the absolute poverty line",
    "fontSize": 16,
    "subtitleFontSize": 13,
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/bonkers69420/2179/refs/heads/main/hh_poverty.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {
      "calculate": "year(toDate(datum.date))",
      "as": "Year"
    },
    {
      "calculate": "toNumber(datum.poverty_absolute)",
      "as": "Rate"
    },
    {
      "filter": "datum.Rate !== null && datum.Rate !== ''"
    }
  ],
  "mark": {
    "type": "line",
    "strokeWidth": 2.5,
    "point": false
  },
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year",
      "axis": {
        "labelAngle": -45,
        "labelFontSize": 11,
        "titleFontSize": 13
      }
    },
    "y": {
      "field": "Rate",
      "type": "quantitative",
      "title": "Poverty Rate (%)",
      "axis": {
        "labelFontSize": 11,
        "titleFontSize": 13,
        "format": ".1f"
      }
    },
    "color": {"value": "#E45756"},
    "tooltip": [
      {"field": "Year", "type": "ordinal", "title": "Year"},
      {"field": "Rate", "type": "quantitative", "title": "Poverty Rate (%)", "format": ".1f"}
    ]
  }
}
