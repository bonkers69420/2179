{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 500,
  "title": {
    "text": "Malaysia Absolute Poverty Rate by State (2022)",
    "subtitle": "Percentage of households below the poverty line",
    "fontSize": 16,
    "subtitleFontSize": 13,
    "anchor": "start"
  },
  "projection": {"type": "mercator"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/bonkers69420/2179/refs/heads/main/malaysia-states-merged.topojson",
        "format": {"type": "topojson", "feature": "states"}
      },
      "transform": [
        {
          "calculate": "datum.properties.Name === 'Penang' ? 'Pulau Pinang' : datum.properties.Name",
          "as": "stateName"
        },
        {
          "lookup": "stateName",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/bonkers69420/2179/refs/heads/main/hh_poverty_state.csv",
              "format": {"type": "csv"}
            },
            "key": "state",
            "fields": ["poverty_absolute", "date"],
            "as": ["poverty_absolute", "date"]
          }
        },
        {
          "filter": "datum.date === '2022-01-01'"
        },
        {
          "calculate": "toNumber(datum.poverty_absolute)",
          "as": "poverty_rate"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "poverty_rate",
          "type": "quantitative",
          "title": "Poverty Rate (%)",
          "scale": {
            "scheme": "orangered",
            "domain": [0, 20]
          },
          "legend": {
            "titleFontSize": 12,
            "labelFontSize": 11,
            "format": ".1f"
          }
        },
        "tooltip": [
          {"field": "stateName", "type": "nominal", "title": "State"},
          {"field": "poverty_rate", "type": "quantitative", "title": "Poverty Rate (%)", "format": ".1f"}
        ]
      }
    }
  ]
}