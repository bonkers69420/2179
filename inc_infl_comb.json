{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "title": {
    "text": "Malaysia Mean Income vs Inflation Rate (1970–2022)",
    "subtitle": "Monthly mean household income (RM) overlaid with annual inflation rate (%)",
    "fontSize": 16,
    "subtitleFontSize": 13,
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/bonkers69420/2179/refs/heads/main/inc_inflation.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"calculate": "year(toDate(datum.date))", "as": "Year"},
    {"calculate": "toNumber(datum.income_mean)", "as": "IncomeMean"},
    {"calculate": "toNumber(datum.inflation_rate)", "as": "InflationRate"}
  ],
  "resolve": {
    "scale": {"y": "independent"}
  },
  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": 0, "labelFontSize": 11, "titleFontSize": 13}
        },
        "y": {
          "field": "IncomeMean",
          "type": "quantitative",
          "title": "Mean Income (RM)",
          "axis": {"labelFontSize": 13, "titleFontSize": 13, "format": ",.0f", "titleColor": "#f0e442"}
        },
        "color": {
          "datum": "Mean Income (RM)",
          "scale": {
            "domain": ["Mean Income (RM)", "Inflation Rate (%)"],
            "range": ["#f0e442", "#d55e00"]
          },
          "legend": {"title": null, "labelFontSize": 12, "orient": "bottom"}
        },
        "tooltip": [
          {"field": "Year", "type": "ordinal", "title": "Year"},
          {"field": "IncomeMean", "type": "quantitative", "title": "Mean Income (RM)", "format": ",.0f"}
        ]
      }
    },
    {
      "mark": {"type": "line", "strokeWidth": 2.5, "point": false},
      "encoding": {
        "x": {"field": "Year", "type": "ordinal"},
        "y": {
          "field": "InflationRate",
          "type": "quantitative",
          "title": "Inflation Rate (%)",
          "axis": {"labelFontSize": 13, "titleFontSize": 13, "format": ".1f", "titleColor": "#d55e00"}
        },
        "color": {
          "datum": "Inflation Rate (%)",
          "scale": {
            "domain": ["Mean Income (RM)", "Inflation Rate (%)"],
            "range": ["#f0e442", "#d55e00"]
          },
          "legend": {"title": null, "labelFontSize": 12, "orient": "bottom"}
        },
        "tooltip": [
          {"field": "Year", "type": "ordinal", "title": "Year"},
          {"field": "InflationRate", "type": "quantitative", "title": "Inflation Rate (%)", "format": ".2f"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.Year === 1974"}],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "dy": 7,
        "fontSize": 12,
        "fontStyle": "italic",
        "color": "#d55e00"
      },
      "encoding": {
        "x": {"field": "Year", "type": "ordinal"},
        "y": {"value": 0},
        "text": {"value": ["▼ Oil Crisis (1974)", "Inflation: 17.4%"]}
      }
    }
  ]
}
